/** index.wxss **/

.container { 
  display: flex; 
  flex-direction: column; 
  background: #ffffff; 
  height: 100vh; 
  box-sizing: border-box;
  overflow: hidden; 
}

/* 核心优化：固定标题栏样式 */
.fixed-header {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100; /* 确保层级高于滚动内容 */
  background: #ffffff;
  padding: 0 40rpx;
  display: flex;
  align-items: center;
  /* 增加轻微的下阴影，在滚动时可以更清晰地界定边界 */
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
  transition: all 0.3s ease;
}

.shelf-scroll {
  flex: 1; 
  width: 100%;
  height: 100vh; /* 确保 scroll-view 撑满屏幕 */
}

/* 顶部编辑占位 */
.edit-placeholder {
  width: 100%;
  background: #ffffff;
}

/* 原有的 header 样式调整：仅用于 fixed-header 内的文本控制 */
.header { 
  transition: opacity 0.3s ease;
}

.list-title { 
  font-size: 48rpx; 
  font-weight: bold; 
  color: #1a1a1a; 
}

/* 简洁版继续阅读区 - 增加平滑过渡 */
.recent-section {
  margin: 20rpx 40rpx 40rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.recent-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.recent-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recent-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  max-width: 70%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recent-progress {
  font-size: 24rpx;
  color: #007aff;
}

/* 悬浮操作按钮组 */
.fab-container {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  z-index: 1000;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.fab-container.hide {
  transform: translate(150rpx, 150rpx) scale(0);
  opacity: 0;
  pointer-events: none;
}

.fab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.12);
  transition: all 0.2s ease;
}

.fab-item:active {
  transform: scale(0.85);
  box-shadow: 0 6rpx 15rpx rgba(0, 0, 0, 0.08);
  opacity: 0.7;
}

.fab-item.mini {
  width: 90rpx;
  height: 90rpx;
  background: transparent !important; 
  border: none !important;
  box-shadow: none !important; 
  display: flex;
  align-items: center;
  justify-content: center;
  filter: drop-shadow(0 8rpx 15rpx rgba(0, 0, 0, 0.2));
  animation: floating 3.5s ease-in-out infinite;
  transition: all 0.2s ease;
}

.fab-item.mini:active {
  animation-play-state: paused;
  transform: scale(0.85);
  filter: drop-shadow(0 2rpx 5rpx rgba(0, 0, 0, 0.1));
}

.fab-item.mini image {
  width: 75rpx;
  height: 75rpx;
}

@keyframes floating {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* 加载状态与空状态适配 */
.loading-state, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.loading-icon {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #1a1a1a;
  border-radius: 50%;
  margin-bottom: 20rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.empty-img { width: 240rpx; height: 240rpx; margin-bottom: 30rpx; opacity: 0.6; }
.empty-title { font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #999; margin-bottom: 40rpx; }

.empty-upload-btn {
  background: #1a1a1a;
  color: white;
  width: 280rpx !important;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 火箭按钮组件适配优化 */
.upload-wrapper {
  padding: 0;
  margin: 0;
  background: transparent;
  overflow: visible;
}

#uploader {
  transform: scale(0.95); /* 微调尺寸，使其与仓库按钮视觉对齐 */
}