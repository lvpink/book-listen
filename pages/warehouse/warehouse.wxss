/** warehouse.wxss **/

/* 1. 基础容器：改用 Flex 垂直布局 */
.container { 
  height: 100vh; 
  display: flex; 
  flex-direction: column; 
  background-color: #ffffff; 
  overflow: hidden; /* 防止容器本身滚动 */
}

/* 顶部固定区域：不再随页面滚动 */
.top-fixed-area {
  flex-shrink: 0;
  background: #ffffff;
  z-index: 1100;
}

/* 优化标题栏间距 */
.header { 
  padding: 20rpx 40rpx 12rpx; /* 缩小了上下内边距：原本是 30/20 */
  background: rgba(255, 255, 255, 0.95); 
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05); 
}
.list-title { 
  font-size: 44rpx; /* 略微调小字体，更显精致 */
  font-weight: bold; 
  color: #1a1a1a; 
  letter-spacing: 1rpx;
  line-height: 1.2; /* 紧凑行高 */
}
.list-subtitle {
  font-size: 22rpx; 
  color: #999; 
  margin-top: 4rpx; /* 缩小标题与统计文字的间距 */
  display: block;
}

/* 核心滚动区：填充剩余空间 */
.library-scroll { 
  flex: 1; 
  height: 0; /* 关键：强制触发 Flex 伸展 */
  width: 100%; 
}

/* --- 2. 仿 App Store 搜索框 (优化版) --- */
.fab-container {
  position: fixed;
  right: 30rpx;
  bottom: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 24rpx;
  z-index: 1000;
  width: calc(100% - 60rpx);
  pointer-events: none;
  transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.fab-container > view,
.fab-container > rocket-button {
  pointer-events: auto;
}

.apple-search {
  display: flex;
  align-items: center;
  height: 90rpx;
  width: 90rpx; 
  border-radius: 45rpx;
  position: relative;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
  background: rgba(255, 255, 255, 0.95);
}

.apple-search.active {
  width: 100%; 
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.search-icon-wrapper {
  width: 90rpx;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 彻底修复：纯 CSS 绘制放大镜 (不再使用 background-color 填充圆圈) */
.custom-search-icon {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #666; /* 放大镜圆环 */
  border-radius: 50%;
  position: relative;
  transition: all 0.3s ease;
  transform: rotate(-45deg);
  background: transparent; /* 确保中间不被填充颜色 */
}

.custom-search-icon::after {
  content: '';
  position: absolute;
  top: 22rpx;
  left: 9rpx;
  width: 4rpx;
  height: 12rpx;
  background-color: #666; /* 放大镜手柄 */
  border-radius: 2rpx;
}

/* 激活状态：圆环和手柄同步变蓝 */
.apple-search.active .custom-search-icon {
  border-color: #007aff; 
}
.apple-search.active .custom-search-icon::after {
  background-color: #007aff;
}

.apple-input {
  flex: 1;
  height: 100%;
  padding: 0 10rpx;
  font-size: 32rpx;
  color: #000;
  opacity: 0;
  transition: opacity 0.2s;
}

.apple-search.active .apple-input {
  opacity: 1;
}

/* --- 3. 清除与取消按钮 --- */
.apple-clear-icon {
  width: 32rpx;
  height: 32rpx;
  background-color: #8e8e93;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 使用转义后的 SVG 确保手机正常显示 */
.apple-clear-icon::before {
  content: '';
  width: 100%;
  height: 100%;
  background-color: #ffffff;
  -webkit-mask-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 3L9 9M9 3L3 9' stroke='black' stroke-width='1.8' stroke-linecap='round'/%3E%3C/svg%3E");
  -webkit-mask-size: 50%;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
}

.apple-cancel {
  padding: 0 30rpx;
  color: #007aff;
  font-size: 32rpx;
  font-weight: 500;
  white-space: nowrap;
  animation: fadeIn 0.4s;
}

/* 缩小内容区顶部的 padding */
.shelf-content {
  padding: 0 10rpx 200rpx;
  margin-top: -10rpx; /* 强制内容上移，抵消组件内边距 */
}

.empty-state {
  margin-top: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateX(20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.top-loading-bar {
  position: fixed; 
  top: 0; left: 0; 
  width: 0; height: 4rpx;
  background: #007aff; 
  z-index: 12000; 
}
.top-loading-bar.loading { 
  width: 100%; 
  transition: width 0.4s ease;
}